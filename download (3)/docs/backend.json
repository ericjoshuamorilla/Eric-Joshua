
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the NEU Library system.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "schoolId": { "type": "string" },
        "rfidTagNumber": { "type": "string" },
        "institutionalEmail": { "type": "string", "format": "email" },
        "userType": { "type": "string", "enum": ["Student", "Faculty", "Staff", "Alumni"] },
        "affiliation": { "type": "string" },
        "isBlocked": { "type": "boolean" },
        "role": { "type": "string", "enum": ["visitor", "admin"] }
      },
      "required": ["id", "name", "institutionalEmail", "userType", "affiliation", "isBlocked", "role"]
    },
    "LibrarySettings": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "LibrarySettings",
      "type": "object",
      "description": "Global configuration for the library system.",
      "properties": {
        "purposes": { "type": "array", "items": { "type": "string" } },
        "openingTime": { "type": "string" },
        "closingTime": { "type": "string" },
        "schoolYear": { "type": "string" },
        "semester": { "type": "string", "enum": ["1st", "2nd", "Midyear"] }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "User profiles."
        }
      },
      {
        "path": "/admin_roles/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "Admin authorization mapping."
        }
      },
      {
        "path": "/settings/{settingId}",
        "definition": {
          "entityName": "LibrarySettings",
          "schema": { "$ref": "#/backend/entities/LibrarySettings" },
          "description": "Global system settings."
        }
      }
    ]
  }
}
